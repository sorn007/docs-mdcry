// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum PublicScopeType {
  file
  folder
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model DocIndex {
  id          String   @id @default(cuid())
  versionHash String
  treeJson    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PublicLink {
  id           String          @id @default(cuid())
  tokenHash    String          @unique
  passwordHash String?
  scopeType    PublicScopeType
  scopeKey     String
  createdAt    DateTime        @default(now())
  expiresAt    DateTime?
  revokedAt    DateTime?
  lastAccessAt DateTime?
  accessLogs   PublicLinkAccessLog[]

  @@index([scopeType, scopeKey])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PublicLinkAccessLog {
  id           String     @id @default(cuid())
  publicLinkId String
  publicLink   PublicLink @relation(fields: [publicLinkId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  ipHash       String?
  userAgent    String?

  @@index([publicLinkId])
  @@index([createdAt])
}
