## Docker Compose deploy environment (image source)
## Usage:
##   cp compose.env.example compose.env
##   docker compose --env-file compose.env up -d

# Full image repository on GHCR (no tag)
GHCR_IMAGE=ghcr.io/<owner>/<repo>

# Image tag to deploy (e.g. latest, v1.2.3, sha-xxxxxxx)
GHCR_TAG=latest

