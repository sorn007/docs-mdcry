# Local/dev — must match POSTGRES_* if you use docker-compose postgres.
# 1) Start DB: docker compose up -d postgres
# 2) Apply schema: npm run db:migrate
# 3) Optional admin: npm run db:seed
DATABASE_URL="postgresql://mdcry:mdcry@localhost:5432/mdcry"

# Admin user for `npm run db:seed`
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-me"
# Set to 1 to overwrite password for existing SEED_ADMIN_USERNAME (recovery after bootstrap / env change)
# SEED_UPDATE_ADMIN_PASSWORD="1"

# Nuxt runtimeConfig (server only)
NUXT_S3_ENDPOINT=""
NUXT_S3_REGION="auto"
NUXT_S3_ACCESS_KEY_ID=""
NUXT_S3_SECRET_ACCESS_KEY=""
NUXT_S3_BUCKET=""

# Optional: only index under this prefix (empty = whole bucket)
NUXT_DOCS_ROOT_PREFIX=""

# Rate limiting: trust X-Forwarded-For first hop (set only behind a trusted reverse proxy)
# NUXT_RATE_LIMIT_TRUST_PROXY="1"

# Send HSTS header (enable only when the site is always served over HTTPS)
# NUXT_SECURITY_HSTS="true"

# Docker Compose Postgres (used by compose file; app DATABASE_URL should match)
# POSTGRES_USER=mdcry
# POSTGRES_PASSWORD=mdcry
# POSTGRES_DB=mdcry

# --- If `prisma migrate deploy` shows P3009 (failed migration 20260324120000_init):
# 1) If DB is disposable: run prisma/cleanup-failed-init.sql (as DB user), then:
#    npx prisma migrate resolve --rolled-back 20260324120000_init
#    npx prisma migrate deploy
# 2) If objects were not created, only: npx prisma migrate resolve --rolled-back 20260324120000_init
#    then npx prisma migrate deploy
# See: https://www.prisma.io/docs/guides/migrate/production-troubleshooting
#
# External Postgres: if you see 42501 "permission denied for database" on migrate,
# the app user needs CREATE on schema public (not necessarily database owner):
#   GRANT CREATE ON SCHEMA public TO your_app_user;
# If CREATE TYPE still fails, ensure USAGE on schema: GRANT USAGE ON SCHEMA public TO your_app_user;

