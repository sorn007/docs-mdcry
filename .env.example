DATABASE_URL="file:./dev.db"

# Owner login bootstrap (used by /api/auth/bootstrap when no user exists)
OWNER_USERNAME="admin"
OWNER_PASSWORD="change-me"

# Nuxt runtimeConfig (server only)
NUXT_S3_ENDPOINT=""
NUXT_S3_REGION="auto"
NUXT_S3_ACCESS_KEY_ID=""
NUXT_S3_SECRET_ACCESS_KEY=""
NUXT_S3_BUCKET=""

# Optional: only index under this prefix (empty = whole bucket)
NUXT_DOCS_ROOT_PREFIX=""

